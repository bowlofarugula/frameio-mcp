# Copy to .env (git-ignored) and fill in your account-specific values.
# These are NOT secrets (Adobe credentials/cookie key are Worker secrets — see README),
# just per-deployment identifiers the tooling needs locally.

# Your OAUTH_KV namespace id. Create one with:
#   npx wrangler kv namespace create OAUTH_KV
# `npm run dev` / `npm run deploy` inject this into the generated wrangler config.
OAUTH_KV_ID=

# Your deployed Worker base URL, used by scripts/e2e.py.
FRAMEIO_MCP_BASE=https://frameio-mcp.<your-subdomain>.workers.dev
