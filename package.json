{
  "name": "frameio-mcp",
  "version": "2.0.0",
  "description": "Remote MCP server on Cloudflare Workers exposing Adobe Frame.io V4 API via the official TypeScript SDK, with Adobe IMS OAuth.",
  "private": true,
  "type": "module",
  "author": "Ian McDonald",
  "repository": {
    "type": "git",
    "url": "https://github.com/bowlofarugula/frameio-mcp.git"
  },
  "homepage": "https://github.com/bowlofarugula/frameio-mcp#readme",
  "scripts": {
    "gen-config": "node scripts/gen-wrangler-config.mjs",
    "dev": "npm run gen-config && wrangler dev --config wrangler.generated.jsonc",
    "deploy": "npm run gen-config && wrangler deploy --config wrangler.generated.jsonc",
    "pretypecheck": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "cf-typegen": "wrangler types"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.14.5",
    "frameio": "^4.2.0",
    "hono": "^4.12.23",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  }
}
